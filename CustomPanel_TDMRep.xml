<?xml version="1.0">
<!DOCTYPE panel SYSTEM "http://ns.adobe.com/custompanels/1.0">
<!-- https://github.com/petervwyatt/AcrobatCustomPanels-->
<panel title="$$$/TDMRep/PanelName=W3C TDMRep" version="1" type="custom_panel">
group(placement: place_column, spacing: gSpace, horizontal: align_left, vertical: align_top)
{
  group(placement: place_row, spacing: gSpace, horizontal: align_fill, reverse: rtl_aware)
  {
    static_text(name: '$$$/TDMRep/reservation=tdm:reservation :', font: font_small_bold_right, vertical: align_top);
    edit_text(  name: '$$$/TDMRep/reservation', horizontal: align_fill, container_type: single_value, xmp_ns_prefix: 'tdm', xmp_namespace: 'http://www.w3.org/ns/tdmrep/', xmp_path: 'tdm:reservation');
  } 
  group(placement: place_row, spacing: gSpace, horizontal: align_fill, reverse: rtl_aware)
  {
    static_text(name: '$$$/TDMRep/policy=tdm:policy :', font: font_small_bold_right, vertical: align_top);
    edit_text(  name: '$$$/TDMRep/policy',  horizontal: align_fill, container_type: single_value, xmp_ns_prefix: 'tdm', xmp_namespace: 'http://www.w3.org/ns/tdmrep/', xmp_path: 'tdm:policy');
  }
	separator(horizontal: align_fill);
	static_text(name: '$$$/TDMRep/Copyright=Version 1.1, Copyright #{copy} Peter Wyatt, 2026', font: font_small_bold, horizontal: align_fill, vertical: align_top, label: false);
}
</panel>
